# Maintainer: Graham Rounds <gtrounds@gmail.com>
pkgname=wayle-agrahamlincoln
pkgver=0.5.2
pkgrel=1
pkgdesc="Compositor-agnostic Wayland desktop shell with bar, dropdowns, notifications, and OSD"
arch=('x86_64')
url="https://github.com/Jas-SinghFSU/wayle"
license=('MIT')
depends=(
    'gtk4'
    'gtk4-layer-shell'
    'gtksourceview5'
    'libpulse'
    'pipewire'
    'fftw'
    'dbus'
    'gcc-libs'
    'glib2'
    'gdk-pixbuf2'
    'hicolor-icon-theme'
)
makedepends=(
    'cargo'
    'pkg-config'
    'clang'
    'cmake'
    'gtksourceview5'
)
provides=('wayle')
conflicts=('wayle')

build() {
    cd "${startdir}/.."
    git submodule update --init --recursive
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # Unset makepkg LDFLAGS/CFLAGS — they break aws-lc-sys's cmake build
    unset LDFLAGS CFLAGS CXXFLAGS
    cargo build --release
}

package() {
    cd "${startdir}/.."
    install -Dm755 "target/release/wayle" "$pkgdir/usr/bin/wayle"
    install -Dm755 "target/release/wayle-shell" "$pkgdir/usr/bin/wayle-shell"
    install -Dm755 "target/release/wayle-settings" "$pkgdir/usr/bin/wayle-settings"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

    # Bundled icons — wayle-icons registers /usr/share/wayle/icons as an icon
    # base dir, so its layout must mirror the user dir IconRegistry creates:
    # index.theme at the base (declaring Directories=hicolor/scalable/actions),
    # with the SVGs under hicolor/scalable/actions. Installing index.theme inside
    # hicolor/ instead makes its relative Directories path resolve to the
    # nonexistent hicolor/hicolor/scalable/actions; on GTK 4.20+ that malformed
    # theme dir poisons the entire icon lookup and every Wayle icon renders as
    # the image-missing fallback.
    install -dm755 "$pkgdir/usr/share/wayle/icons/hicolor/scalable/actions"
    install -Dm644 resources/icons/hicolor/scalable/actions/*.svg \
        -t "$pkgdir/usr/share/wayle/icons/hicolor/scalable/actions"
    install -Dm644 resources/icons/index.theme \
        "$pkgdir/usr/share/wayle/icons/index.theme"
}
